{
	"luci-app-peripherals": {
		"description": "Peripherals (IR, fan, diagnostics)",
		"read": {
			"ubus": {
				"luci.peripherals": [
					"irMapsGet",
					"irKeymapsList",
					"irDevices",
					"moduleDiagnostics",
					"debugReport",
					"fanGet",
					"oledGet",
					"oledDetect"
				]
			},
			"uci": [ "oled", "luci_peripherals" ]
		},
		"write": {
			"ubus": {
				"luci.peripherals": [
					"irMapsSet",
					"irApply",
					"fanSet",
					"fanTest"
				]
			},
			"uci": [ "luci_peripherals" ],
			"file": {
				"/etc/rc_maps.cfg": [ "write" ],
				"/usr/bin/ir-keytable": [ "exec" ],
				"/usr/sbin/i2cdetect": [ "exec" ],
				"/usr/bin/i2cdetect": [ "exec" ],
				"/sys/class/hwmon": [ "read", "write" ]
			}
		}
	}
}
