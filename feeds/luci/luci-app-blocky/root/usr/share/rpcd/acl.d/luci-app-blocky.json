{
	"luci-app-blocky": {
		"description": "Grant access to Blocky LuCI app",
		"read": {
			"uci": [ "blocky" ],
			"file": {
				"/etc/blocky/config.yml": [ "read" ],
				"/etc/init.d/blocky": [ "exec" ],
				"/usr/sbin/blocky-dnsmasq-sync": [ "exec" ],
				"/usr/share/luci-app-blocky/blocklist-catalog.json": [ "read" ]
			},
			"ubus": {
				"service": [ "list" ],
				"luci.blocky": [ "sync_lists", "refresh_lists", "http_request", "read_query_log", "get_version" ]
			}
		},
		"write": {
			"uci": [ "blocky" ],
			"file": {
				"/etc/blocky/config.yml": [ "write" ],
				"/etc/init.d/blocky": [ "exec" ],
				"/usr/sbin/blocky-dnsmasq-sync": [ "exec" ],
				"/usr/sbin/blocky-lists-sync": [ "exec" ],
				"/usr/sbin/blocky-lists-refresh": [ "exec" ],
				"/usr/sbin/blocky-http-api": [ "exec" ]
			},
			"ubus": {
				"luci.blocky": [ "sync_lists", "refresh_lists", "http_request", "read_query_log", "get_version" ]
			}
		}
	}
}
