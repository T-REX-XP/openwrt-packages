{
	"luci-app-oled": {
		"description": "Grant access for luci-app-oled (OLED display configuration)",
		"read": {
			"ubus": {
				"luci.oled": [
					"getConfig",
					"getStatus",
					"detectI2c",
					"getLogs"
				],
				"oledd": [ "status" ]
			},
			"uci": [ "oled" ],
			"file": {
				"/tmp/oled_state": [ "read" ],
				"/dev/i2c-*": [ "read" ],
				"/sbin/logread": [ "exec" ],
				"/bin/logread": [ "exec" ],
				"/usr/sbin/i2cdetect": [ "exec" ],
				"/usr/bin/i2cdetect": [ "exec" ]
			}
		},
		"write": {
			"ubus": {
				"luci.oled": [
					"setConfig",
					"releaseRst",
					"serviceControl"
				]
			},
			"uci": [ "oled" ],
			"file": {
				"/etc/init.d/oled": [ "exec" ],
				"/etc/init.d/oledd": [ "exec" ],
				"/usr/lib/oled/cm5-apply-config.sh": [ "read", "exec" ],
				"/sys/class/leds/waveshare-oled-rst/brightness": [ "write" ],
				"/usr/sbin/i2cdetect": [ "exec" ],
				"/usr/bin/i2cdetect": [ "exec" ]
			}
		}
	}
}
