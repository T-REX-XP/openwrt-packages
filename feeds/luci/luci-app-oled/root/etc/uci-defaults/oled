#!/bin/sh

uci_write_config() {
	[[ `uci -q get oled.@oled[0].showmenu` -eq 1 ]] && return
	uci -q batch <<-EOF >/dev/null
		set oled.@oled[0].showmenu="1"
		set oled.@oled[0].enable="1"
		set oled.@oled[0].path="$1"
		set oled.@oled[0].rotate="$2"
		set oled.@oled[0].netspeed="$3"
		set oled.@oled[0].netsource="$4"
		set oled.@oled[0].ipifname="br-lan"
		commit oled
EOF
}

. /lib/functions/system.sh

cm5_oled_i2c_path() {
	local dev bus
	for dev in /dev/i2c-*; do
		[ -c "$dev" ] || continue
		bus="${dev#/dev/i2c-}"
		# Onboard RTC only — not the FPC OLED bus
		[ "$bus" = "1" ] && continue
		# i2cdetect on CM5 FPC can show a noisy grid; probe 0x3c directly
		i2cget -y "$bus" 0x3c 0x00 b >/dev/null 2>&1 || continue
		echo "$dev"
		return 0
	done
	return 1
}

uci -q delete oled.@oled[0].chip 2>/dev/null

case "$(board_name)" in
xunlong,orangepi-cm5-base)
	if cm5_path="$(cm5_oled_i2c_path)"; then
		uci_write_config "$cm5_path" 0 0 br-lan
	else
		uci -q batch <<-EOF >/dev/null
			set oled.@oled[0].showmenu="1"
			set oled.@oled[0].enable="0"
			set oled.@oled[0].path="/dev/i2c-7"
			set oled.@oled[0].ipifname="br-lan"
			set oled.@oled[0].netsource="br-lan"
			commit oled
EOF
	fi
	;;
esac

if [ "$(uci -q get oled.@oled[0].enable)" = "1" ]; then
	/etc/init.d/oled enable
	/etc/init.d/oled start
fi

uci -q batch <<-EOF >/dev/null
	delete ucitrack.@oled[-1]
	add ucitrack oled
	set ucitrack.@oled[-1].init=oled
	commit ucitrack
EOF

sed -e "/\/etc\/init\.d\/oled/d" -i /etc/crontabs/root && /etc/init.d/cron reload
rm -rf /tmp/luci-*
exit 0
