#!/bin/sh /etc/rc.common

START=09
STOP=90
USE_PROCD=1
PROG=/usr/sbin/oledd

get_section() {
	eval "export -n ${2}=\"$1\""
	return 1
}

start_service() {
	local mainsection
	config_load oled
	config_foreach get_section oled mainsection
	local section=$mainsection

	local enabled menu_mode
	config_get enabled "$section" enable 0
	config_get menu_mode "$section" menu_mode 0
	[ "$enabled" = "1" ] || return 1
	[ "$menu_mode" = "1" ] || return 1

	local i2c_path retries=0
	config_get i2c_path "$section" path "/dev/i2c-7"
	while [ ! -c "$i2c_path" ] && [ "$retries" -lt 15 ]; do
		sleep 1
		retries=$((retries + 1))
	done

	if [ -x /usr/lib/oled/oled-boot-state.sh ]; then
		boot_stage=$(grep -m1 '^stage=' /tmp/oled_state 2>/dev/null | cut -d= -f2)
		case "$boot_stage" in
		ready|network) ;;
		*)
			/usr/lib/oled/oled-boot-state.sh boot "Starting oledd..."
			;;
		esac
		# LAN may already be up before hotplug runs (oledd respawn, late start).
		if [ -d /sys/class/net/br-lan ]; then
			br_state=$(cat /sys/class/net/br-lan/operstate 2>/dev/null)
			case "$br_state" in
			up|unknown)
				/usr/lib/oled/oled-boot-state.sh ready "LAN up" 2>/dev/null || true
				;;
			esac
		fi
	fi

	procd_open_instance
	procd_set_param command ${PROG}
	procd_set_param stderr 1
	procd_set_param stdout 1

	local param
	config_get param "$section" path
	[ -n "$param" ] && procd_append_param command --i2cDevPath="$param"

	config_get param "$section" rotate
	[ "$param" = "1" ] && procd_append_param command --rotate

	config_get param "$section" menu_timeout
	[ -n "$param" ] && procd_append_param command --view-timeout="$param"

	config_get param "$section" menu_idle_dim
	[ -n "$param" ] && procd_append_param command --idle-dim-sec="$param"

	procd_set_param respawn 3600 5 0
	procd_close_instance
}

stop_service() {
	:
}

service_triggers() {
	procd_add_reload_trigger "oled"
	procd_add_interface_trigger "interface.*" lan /usr/lib/oled/oled-boot-state.sh ready "LAN up"
}
