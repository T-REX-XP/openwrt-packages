#!/bin/sh /etc/rc.common

START=80
USE_PROCD=1

PROG=/usr/bin/blocky
CONFIG=/etc/blocky/config.yml

start_service() {
	procd_open_instance
	procd_set_param command "$PROG" --config "$CONFIG"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}
