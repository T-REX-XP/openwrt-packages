#!/bin/sh
# Merge /etc/config/blocky blocklist sections into blocking: in /etc/blocky/config.yml

. /lib/functions.sh

CONFIG_YML=/etc/blocky/config.yml
DENY_TMP=
GROUP_TMP=

sanitize_id() {
	echo "$1" | tr 'A-Z' 'a-z' | tr -c 'a-z0-9_' '_' | sed 's/_*$//; s/^_*//'
}

yaml_double_quote() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

cleanup() {
	[ -n "$DENY_TMP" ] && rm -f "$DENY_TMP"
	[ -n "$GROUP_TMP" ] && rm -f "$GROUP_TMP"
}

append_denylist_entry() {
	local section="$1"
	local id name url enabled

	config_get name "$section" name "$section"
	config_get url "$section" url ""
	config_get enabled "$section" enabled "1"

	[ -n "$url" ] || return 0

	id="$(sanitize_id "$section")"
	[ -n "$id" ] || return 0

	if grep -q "^    ${id}:$" "$DENY_TMP" 2>/dev/null; then
		printf '      - "%s"\n' "$(yaml_double_quote "$url")" >> "$DENY_TMP"
	else
		printf '    %s:\n' "$id" >> "$DENY_TMP"
		printf '      - "%s"\n' "$(yaml_double_quote "$url")" >> "$DENY_TMP"
	fi

	if [ "$enabled" = "1" ] && ! grep -qxF "$id" "$GROUP_TMP" 2>/dev/null; then
		printf '%s\n' "$id" >> "$GROUP_TMP"
	fi
}

write_blocking_section() {
	local refresh_period out_tmp

	config_load blocky
	config_get refresh_period main refresh_period "4h"
	[ -n "$refresh_period" ] || refresh_period="4h"

	DENY_TMP="$(mktemp)"
	GROUP_TMP="$(mktemp)"
	out_tmp="$(mktemp)"

	config_foreach append_denylist_entry blocklist

	if [ ! -s "$DENY_TMP" ]; then
		printf '    hagezi_light:\n' >> "$DENY_TMP"
		printf '      - "https://raw.githubusercontent.com/hagezi/dns-blocklists/main/domains/light.txt"\n' >> "$DENY_TMP"
		printf '    urlhaus:\n' >> "$DENY_TMP"
		printf '      - "https://urlhaus.abuse.ch/downloads/hostfile/"\n' >> "$DENY_TMP"
		printf 'hagezi_light\nurlhaus\n' >> "$GROUP_TMP"
	fi

	{
		echo "blocking:"
		echo "  denylists:"
		cat "$DENY_TMP"
		echo "  clientGroupsBlock:"
		echo "    default:"
		if [ -s "$GROUP_TMP" ]; then
			sed 's/^/      - /' "$GROUP_TMP"
		else
			echo "      - hagezi_light"
		fi
		echo "  loading:"
		echo "    strategy: fast"
		echo "    refreshPeriod: $refresh_period"
		echo "    downloads:"
		echo "      cachePath: /var/lib/blocky/lists"
		echo "      timeout: 60s"
		echo "      writeTimeout: 60s"
		echo "      readTimeout: 60s"
		echo "      attempts: 5"
		echo "      cooldown: 10s"
		echo "    concurrency: 4"
	} > "$out_tmp"

	echo "$out_tmp"
}

# Print the first well-formed top-level YAML section with the given name.
extract_first_section() {
	local section="$1"
	local file="$2"

	[ -n "$section" ] && [ -f "$file" ] || return 1

	awk -v sec="$section" '
		$0 ~ "^" sec ":[[:space:]]*$" && !found {
			found = 1
			print
			next
		}
		found {
			if ($0 ~ "^" sec ":[[:space:]]*$")
				exit
			if ($0 ~ /^[^[:space:]#]/ && $0 !~ "^" sec ":[[:space:]]*$")
				exit
			print
		}
	' "$file"
}

merge_config() {
	local new_blocking="$1"
	local merged_tmp section body

	merged_tmp="$(mktemp)"

	section_body() {
		local name="$1"
		local body

		body="$(extract_first_section "$name" "$CONFIG_YML" 2>/dev/null || true)"
		case "$name" in
			queryLog)
				echo "$body" | grep -q 'type:' || body=""
				;;
			ports)
				echo "$body" | grep -q 'dns:' || body=""
				;;
			prometheus|statistics)
				echo "$body" | grep -q 'enable:' || body=""
				;;
			bootstrapDns)
				echo "$body" | grep -Eq 'resolvFile:|tcp|https:' || body=""
				;;
			caching)
				echo "$body" | grep -Eq 'minTime:|maxTime:|prefetching:' || body=""
				;;
			log)
				echo "$body" | grep -q 'level:' || body=""
				;;
			hostsFile)
				echo "$body" | grep -q 'sources:' || body=""
				;;
			rebindingProtection)
				echo "$body" | grep -q 'enable:' || body=""
				;;
		esac
		printf '%s' "$body"
	}

	append_section() {
		local name="$1"
		local default="$2"

		body="$(section_body "$name")"
		if [ -n "$body" ]; then
			printf '%s\n' "$body"
		else
			printf '%s\n' "$default"
		fi
	}

	{
		if extract_first_section upstreams "$CONFIG_YML"; then
			:
		else
			cat <<'EOF'
upstreams:
  init:
    strategy: fast
  timeout: 5s
  groups:
    default:
      - 1.1.1.1
      - 9.9.9.9
      - tcp-tls:1.1.1.1:853
      - https://1.1.1.1/dns-query
EOF
		fi
		echo ""
		append_section bootstrapDns 'bootstrapDns:
  - tcp+udp:1.1.1.1
  - resolvFile: /tmp/resolv.conf.auto'
		echo ""
		cat "$new_blocking"
		echo ""
		append_section caching 'caching:
  minTime: 5m
  maxTime: 30m
  prefetching: false'
		echo ""
		append_section hostsFile 'hostsFile:
  sources:
    - /etc/hosts'
		echo ""
		append_section log 'log:
  level: warn
  privacy: false'
		echo ""
		body="$(section_body queryLog)"
		if [ -n "$body" ]; then
			printf '%s\n' "$body"
		else
			cat <<'EOF'
queryLog:
  type: csv
  target: /tmp/blocky-logs
  logRetentionDays: 7
  flushInterval: 30s
EOF
		fi
		echo ""
		body="$(section_body ports)"
		if [ -n "$body" ]; then
			printf '%s\n' "$body"
		else
			cat <<'EOF'
ports:
  dns: 127.0.0.1:5353
  http: 127.0.0.1:4000
EOF
		fi
		echo ""
		append_section rebindingProtection 'rebindingProtection:
  enable: true'
		echo ""
		body="$(section_body prometheus)"
		if [ -n "$body" ]; then
			printf '%s\n' "$body"
		else
			cat <<'EOF'
prometheus:
  enable: true
  path: /metrics
EOF
		fi
		echo ""
		body="$(section_body statistics)"
		if [ -n "$body" ]; then
			printf '%s\n' "$body"
		else
			cat <<'EOF'
statistics:
  enable: true
EOF
		fi
	} > "$merged_tmp"

	mv "$merged_tmp" "$CONFIG_YML"
}

main() {
	local blocking_file

	[ -s "$CONFIG_YML" ] || {
		echo "blocky-lists-sync: missing $CONFIG_YML" >&2
		exit 1
	}

	trap cleanup EXIT

	cp "$CONFIG_YML" "$CONFIG_YML.bak.lists-sync" 2>/dev/null || true

	blocking_file="$(write_blocking_section)"
	merge_config "$blocking_file"
	rm -f "$blocking_file"
}

main "$@"
