#!/bin/sh
# Shared Blocky HTTP helpers (sourced by init scripts) and LuCI CLI entry point.
# LuCI/rpcd cannot run uclient-fetch to localhost; exec this script instead:
#   blocky-http-api GET metrics
#   blocky-http-api GET api/stats
#   blocky-http-api POST api/cache/flush

CONFIG="${BLOCKY_CONFIG:-/etc/blocky/config.yml}"
BLOCKY_HTTP_HOST_DEFAULT='127.0.0.1'
BLOCKY_HTTP_PORT_DEFAULT='4000'

blocky_http_port() {
	local line hostport port

	[ -s "$CONFIG" ] || {
		echo "$BLOCKY_HTTP_PORT_DEFAULT"
		return 0
	}

	line="$(awk '
		/^ports:[[:space:]]*$/ { in_ports=1; next }
		in_ports && /^[^[:space:]#]/ && !/^  / { exit }
		in_ports && /^  http:/ {
			sub(/^  http:[[:space:]]*/, "")
			gsub(/["'"'"']/, "")
			sub(/#.*$/, "")
			print
			exit
		}
	' "$CONFIG" 2>/dev/null)" || true

	[ -n "$line" ] || {
		echo "$BLOCKY_HTTP_PORT_DEFAULT"
		return 0
	}

	hostport="$line"
	case "$hostport" in
		*:*)
			port="${hostport##*:}"
			;;
		[0-9]*)
			port="$hostport"
			;;
		*)
			port="$BLOCKY_HTTP_PORT_DEFAULT"
			;;
	esac

	echo "${port:-$BLOCKY_HTTP_PORT_DEFAULT}"
}

blocky_api_base() {
	printf 'http://%s:%s/api\n' "$BLOCKY_HTTP_HOST_DEFAULT" "$(blocky_http_port)"
}

blocky_http_client() {
	if command -v uclient-fetch >/dev/null 2>&1; then
		echo uclient-fetch
	elif command -v wget >/dev/null 2>&1; then
		echo wget
	else
		return 1
	fi
}

blocky_http_probe() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O /dev/null --timeout=2 "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O /dev/null -T 2 "$url" 2>/dev/null
			;;
	esac
}

blocky_http_get() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=10 "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 10 "$url" 2>/dev/null
			;;
	esac
}

blocky_http_post_empty() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O /dev/null --timeout=180 --method=POST "$url"
			;;
		wget)
			wget -4 -q -O /dev/null -T 180 --post-data='' "$url"
			;;
	esac
}

blocky_http_post_json() {
	local url="$1"
	local body="$2"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=30 \
				--post-type=application/json \
				--post-data="$body" \
				"$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 30 \
				--header='Content-Type: application/json' \
				--post-data="$body" \
				"$url" 2>/dev/null
			;;
	esac
}

blocky_http_post() {
	local url="$1"
	local body="${2:-}"

	if [ -n "$body" ]; then
		blocky_http_post_json "$url" "$body"
		return $?
	fi

	case "$(blocky_http_client)" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=180 --method=POST "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 180 --post-data='' "$url" 2>/dev/null
			;;
	esac
}

blocky_wait_for_api() {
	local base="$1"
	local max_wait="${2:-90}"
	local i=0

	while [ "$i" -lt "$max_wait" ]; do
		if blocky_http_probe "$base/blocking/status"; then
			return 0
		fi
		i=$((i + 1))
		sleep 1
	done

	return 1
}

# Wait until the router can reach the public internet (IPv4).
# List downloads and DoH bootstrap need a default route; Tailscale/wan may come up late.
blocky_wait_for_network() {
	local max_wait="${1:-120}"
	local i=0

	while [ "$i" -lt "$max_wait" ]; do
		if ip route get 1.1.1.1 >/dev/null 2>&1; then
			if uclient-fetch -4 -q -O /dev/null --timeout=3 http://1.1.1.1/ 2>/dev/null; then
				return 0
			fi
			# Route exists but probe failed — keep waiting briefly.
		fi
		i=$((i + 1))
		sleep 1
	done

	return 1
}

blocky_http_request_cli() {
	local method="${1:-GET}"
	local path_part="${2:-metrics}"
	local body="${3:-}"
	local base url

	case "$method" in
		GET|POST) ;;
		*)
			echo "blocky-http-api: unsupported method: $method" >&2
			return 2
			;;
	esac

	path_part="${path_part#/}"
	base="http://${BLOCKY_HTTP_HOST_DEFAULT}:$(blocky_http_port)"

	case "$path_part" in
		metrics|metrics/*)
			url="${base}/metrics"
			;;
		api/*)
			url="${base}/${path_part}"
			;;
		*)
			url="${base}/api/${path_part}"
			;;
	esac

	case "$method" in
		GET)
			blocky_http_get "$url" || {
				echo "blocky-http-api: GET $url failed" >&2
				return 1
			}
			;;
		POST)
			blocky_http_post "$url" "$body" || {
				echo "blocky-http-api: POST $url failed" >&2
				return 1
			}
			;;
	esac

	return 0
}

# CLI mode when executed (not sourced).
case "$0" in
	*/blocky-http-api|*/blocky-http-request)
		[ "${BLOCKY_HTTP_API_SOURCED:-}" = "1" ] && return 0 2>/dev/null || true
		if [ $# -gt 0 ]; then
			blocky_http_request_cli "$@"
			exit $?
		fi
		;;
esac
