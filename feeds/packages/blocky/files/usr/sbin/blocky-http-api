#!/bin/sh
# Shared helpers for Blocky HTTP API calls on localhost (LuCI / init scripts).

CONFIG="${BLOCKY_CONFIG:-/etc/blocky/config.yml}"
BLOCKY_HTTP_HOST_DEFAULT='127.0.0.1'
BLOCKY_HTTP_PORT_DEFAULT='4000'

blocky_http_port() {
	local line hostport port

	[ -s "$CONFIG" ] || {
		echo "$BLOCKY_HTTP_PORT_DEFAULT"
		return 0
	}

	line="$(grep -E '^[[:space:]]+http:' "$CONFIG" | head -1)" || true
	[ -n "$line" ] || {
		echo "$BLOCKY_HTTP_PORT_DEFAULT"
		return 0
	}

	hostport="$(echo "$line" | sed -n 's/^[[:space:]]*http:[[:space:]]*//p' | tr -d "\"'" | sed 's/#.*$//')"
	case "$hostport" in
		*:*)
			port="${hostport##*:}"
			;;
		[0-9]*)
			port="$hostport"
			;;
		*)
			port="$BLOCKY_HTTP_PORT_DEFAULT"
			;;
	esac

	echo "${port:-$BLOCKY_HTTP_PORT_DEFAULT}"
}

blocky_api_base() {
	printf 'http://%s:%s/api\n' "$BLOCKY_HTTP_HOST_DEFAULT" "$(blocky_http_port)"
}

blocky_http_client() {
	if command -v uclient-fetch >/dev/null 2>&1; then
		echo uclient-fetch
	elif command -v wget >/dev/null 2>&1; then
		echo wget
	else
		return 1
	fi
}

blocky_http_probe() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O /dev/null --timeout=2 "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O /dev/null -T 2 "$url" 2>/dev/null
			;;
	esac
}

blocky_http_get() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=10 "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 10 "$url" 2>/dev/null
			;;
	esac
}

blocky_http_post_empty() {
	local url="$1"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O /dev/null --timeout=180 --post-data='' "$url"
			;;
		wget)
			wget -4 -q -O /dev/null -T 180 --post-data='' "$url"
			;;
	esac
}

blocky_http_post_json() {
	local url="$1"
	local body="$2"
	local client

	client="$(blocky_http_client)" || return 1

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=30 \
				--post-type=application/json \
				--post-data="$body" \
				"$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 30 \
				--header='Content-Type: application/json' \
				--post-data="$body" \
				"$url" 2>/dev/null
			;;
	esac
}

blocky_http_post() {
	local url="$1"
	local body="${2:-}"
	local client

	client="$(blocky_http_client)" || return 1

	if [ -n "$body" ]; then
		blocky_http_post_json "$url" "$body"
		return $?
	fi

	case "$client" in
		uclient-fetch)
			uclient-fetch -4 -q -O - --timeout=180 --post-data='' "$url" 2>/dev/null
			;;
		wget)
			wget -4 -q -O - -T 180 --post-data='' "$url" 2>/dev/null
			;;
	esac
}

blocky_wait_for_api() {
	local base="$1"
	local max_wait="${2:-90}"
	local i=0

	while [ "$i" -lt "$max_wait" ]; do
		if blocky_http_probe "$base/blocking/status"; then
			return 0
		fi
		i=$((i + 1))
		sleep 1
	done

	return 1
}
