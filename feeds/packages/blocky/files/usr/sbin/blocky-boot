#!/bin/sh
# After Blocky starts: ensure API blocking is on and remote lists are refreshed.

set -u

. /usr/sbin/blocky-http-api

API="$(blocky_api_base)"
MAX_WAIT=90

enable_blocking() {
	local status

	status="$(blocky_http_get "$API/blocking/status")" || return 0

	case "$status" in
		*'"enabled":true'*|*'"enabled": true'*)
			return 0
			;;
	esac

	blocky_http_get "$API/blocking/enable" >/dev/null || true
}

blocky_wait_for_api "$API" "$MAX_WAIT" || exit 0
enable_blocking
blocky_http_post_empty "$API/lists/refresh" || true

exit 0
