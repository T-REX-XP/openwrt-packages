#!/bin/sh
# After Blocky starts: wait for WAN, enable blocking, refresh remote lists.

set -u

. /usr/sbin/blocky-http-api

API="$(blocky_api_base)"
MAX_WAIT=90
NET_WAIT=120

enable_blocking() {
	local status

	status="$(blocky_http_get "$API/blocking/status")" || return 0

	case "$status" in
		*'"enabled":true'*|*'"enabled": true'*)
			return 0
			;;
	esac

	blocky_http_get "$API/blocking/enable" >/dev/null || true
}

blocky_wait_for_api "$API" "$MAX_WAIT" || exit 0

if ! blocky_wait_for_network "$NET_WAIT"; then
	logger -t blocky "WAN not ready — deferring list refresh (hotplug will retry)"
	exit 0
fi

enable_blocking

if blocky_http_post_empty "$API/lists/refresh"; then
	logger -t blocky "block lists refreshed"
else
	logger -t blocky "list refresh failed — will retry on next WAN ifup"
fi

exit 0
