#!/bin/sh
# Proxy Blocky HTTP calls for LuCI (rpcd cannot uclient-fetch localhost).
#
# Usage:
#   blocky-http-request GET metrics
#   blocky-http-request GET api/stats
#   blocky-http-request GET api/blocking/status
#   blocky-http-request POST api/cache/flush
#   blocky-http-request POST api/query '{"query":"example.com","type":"A"}'

set -u

. /usr/sbin/blocky-http-api

METHOD="${1:-GET}"
PATH_PART="${2:-metrics}"
BODY="${3:-}"

case "$METHOD" in
	GET|POST) ;;
	*)
		echo "blocky-http-request: unsupported method: $METHOD" >&2
		exit 2
		;;
esac

PATH_PART="${PATH_PART#/}"

BASE="http://${BLOCKY_HTTP_HOST_DEFAULT}:$(blocky_http_port)"

case "$PATH_PART" in
	metrics|metrics/*)
		URL="${BASE}/metrics"
		;;
	api/*)
		URL="${BASE}/${PATH_PART}"
		;;
	*)
		URL="${BASE}/api/${PATH_PART}"
		;;
esac

case "$METHOD" in
	GET)
		blocky_http_get "$URL" || {
			echo "blocky-http-request: GET $URL failed" >&2
			exit 1
		}
		;;
	POST)
		blocky_http_post "$URL" "$BODY" || {
			echo "blocky-http-request: POST $URL failed" >&2
			exit 1
		}
		;;
esac

exit 0
